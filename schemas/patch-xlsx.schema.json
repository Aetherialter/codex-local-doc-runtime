{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Aetherialter/codex-local-doc-runtime/schemas/patch-xlsx.schema.json",
  "title": "docrt XLSX patch",
  "type": "object",
  "required": ["document_type", "operations"],
  "properties": {
    "document_type": { "const": "xlsx" },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "sheet", "cell", "value"],
            "properties": {
              "type": { "const": "set_cell" },
              "sheet": { "type": "string" },
              "cell": { "type": "string" },
              "value": {},
              "expected_value": {}
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "sheet", "start_cell", "values"],
            "properties": {
              "type": { "const": "set_range_values" },
              "sheet": { "type": "string" },
              "start_cell": { "type": "string" },
              "values": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "array" }
              },
              "expected_values": {
                "type": "array",
                "items": { "type": "array" }
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "name"],
            "properties": {
              "type": { "const": "add_sheet" },
              "name": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "old_name", "new_name"],
            "properties": {
              "type": { "const": "rename_sheet" },
              "old_name": { "type": "string" },
              "new_name": { "type": "string" }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
